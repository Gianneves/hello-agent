{
  "compilerOptions": {
    "target": "es2022",                               
    "lib": ["es2022", "DOM"],                                       
    "module": "esnext",                          
    "moduleResolution": "bundler",                       
    "esModuleInterop": true,                            
    "forceConsistentCasingInFileNames": true,           
    "strict": true,                                      
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src"]
}
